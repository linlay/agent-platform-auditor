{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zenmind.local/platform-auditor/schemas/jsonl/submit.schema.json",
  "type": "object",
  "required": ["chatId", "runId", "updatedAt", "_type"],
  "additionalProperties": false,
  "properties": {
    "chatId": { "type": "string" },
    "runId": { "type": "string" },
    "updatedAt": { "type": "number" },
    "liveSeq": {
      "$ref": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json#/definitions/positiveInteger"
    },
    "_type": { "type": "string", "enum": ["submit"] },
    "submit": { "type": "object", "additionalProperties": true },
    "answer": { "type": "object", "additionalProperties": true }
  }
}
