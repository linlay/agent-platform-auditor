{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zenmind.local/platform-auditor/schemas/jsonl/query.schema.json",
  "type": "object",
  "required": ["chatId", "runId", "updatedAt", "query", "messages", "_type"],
  "additionalProperties": false,
  "properties": {
    "chatId": { "type": "string" },
    "runId": { "type": "string" },
    "updatedAt": { "type": "number" },
    "liveSeq": {
      "$ref": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json#/definitions/positiveInteger"
    },
    "taskId": { "type": "string" },
    "taskName": { "type": "string" },
    "taskToolId": { "type": "string" },
    "subAgentKey": { "type": "string" },
    "query": {
      "$ref": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json#/definitions/queryPayload"
    },
    "messages": {
      "$ref": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json#/definitions/llmChatMessages"
    },
    "_type": { "type": "string", "enum": ["query"] },
    "system": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "toolChoice": {
          "$ref": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json#/definitions/llmToolChoice"
        },
        "requestOptions": {
          "$ref": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json#/definitions/llmRequestOptions"
        }
      }
    },
    "hidden": { "type": "boolean" }
  }
}
