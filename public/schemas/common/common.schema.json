{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zenmind.local/platform-auditor/schemas/common/common.schema.json",
  "definitions": {
    "role": {
      "type": "string",
      "enum": ["user", "assistant", "system", "tool"]
    },
    "queryRole": {
      "type": "string",
      "enum": ["user", "assistant", "automation", "system"]
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "accessLevel": {
      "type": "string",
      "enum": ["default", "admin", "owner"]
    },
    "taskStatus": {
      "type": "string",
      "enum": ["running", "completed", "failed", "cancelled", "pending"]
    },
    "planExecuteStage": {
      "type": "string",
      "enum": ["plan", "execute", "summary"]
    },
    "streamEventType": {
      "type": "string",
      "enum": [
        "request.query",
        "awaiting.ask",
        "awaiting.answer",
        "request.submit",
        "request.steer",
        "chat.start",
        "run.start",
        "debug.preCall",
        "debug.postCall",
        "usage.snapshot",
        "memory.write",
        "memory.read",
        "memory.search",
        "memory.update",
        "memory.forget",
        "memory.timeline",
        "memory.promote",
        "memory.consolidate",
        "run.complete",
        "run.cancel",
        "run.error",
        "reasoning.start",
        "reasoning.delta",
        "reasoning.end",
        "reasoning.snapshot",
        "content.start",
        "content.delta",
        "content.end",
        "content.snapshot",
        "tool.start",
        "tool.args",
        "tool.end",
        "tool.snapshot",
        "tool.result",
        "source.publish",
        "action.start",
        "action.args",
        "action.end",
        "action.snapshot",
        "action.result",
        "plan.create",
        "plan.update",
        "planning.delta",
        "planning.snapshot",
        "task.start",
        "task.complete",
        "task.cancel",
        "task.error",
        "artifact.publish"
      ]
    },
    "queryPayload": {
      "type": "object",
      "required": ["requestId", "chatId", "role", "message", "runId"],
      "additionalProperties": false,
      "properties": {
        "requestId": { "type": "string" },
        "chatId": { "type": "string" },
        "role": { "$ref": "#/definitions/queryRole" },
        "message": { "type": "string" },
        "runId": { "type": "string" },
        "agentKey": { "type": "string" },
        "teamId": {},
        "model": { "type": "object", "additionalProperties": true },
        "accessLevel": { "$ref": "#/definitions/accessLevel" },
        "liveSeq": { "$ref": "#/definitions/positiveInteger" },
        "references": {},
        "params": {},
        "scene": {},
        "stream": { "type": "boolean" },
        "planningMode": { "type": "boolean" }
      }
    },
    "contextWindow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxSize": { "type": "number" },
        "currentSize": { "type": "number" },
        "estimatedNextCallSize": { "type": "number" }
      }
    },
    "estimatedCost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": { "type": "string" },
        "inputCacheHit": { "$ref": "#/definitions/nonNegativeNumber" },
        "inputCacheMiss": { "$ref": "#/definitions/nonNegativeNumber" },
        "output": { "$ref": "#/definitions/nonNegativeNumber" },
        "total": { "$ref": "#/definitions/nonNegativeNumber" }
      }
    },
    "usageTiming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstTokenLatencyMs": { "$ref": "#/definitions/nonNegativeInteger" },
        "generationDurationMs": { "$ref": "#/definitions/nonNegativeInteger" }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promptTokens": { "type": "number", "minimum": 0 },
        "completionTokens": { "type": "number", "minimum": 0 },
        "totalTokens": { "type": "number", "minimum": 0 },
        "llmChatCompletionCount": { "type": "number", "minimum": 0 },
        "toolCallCount": { "type": "number", "minimum": 0 },
        "promptTokensDetails": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cacheHitTokens": { "$ref": "#/definitions/nonNegativeNumber" },
            "cacheMissTokens": { "$ref": "#/definitions/nonNegativeNumber" }
          }
        },
        "completionTokensDetails": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reasoningTokens": { "$ref": "#/definitions/nonNegativeNumber" }
          }
        },
        "estimatedCost": { "$ref": "#/definitions/estimatedCost" },
        "timing": { "$ref": "#/definitions/usageTiming" }
      }
    },
    "reactUsage": {
      "type": "object",
      "required": ["promptTokens", "completionTokens", "totalTokens"],
      "additionalProperties": false,
      "properties": {
        "promptTokens": { "$ref": "#/definitions/nonNegativeInteger" },
        "completionTokens": { "$ref": "#/definitions/nonNegativeInteger" },
        "totalTokens": { "$ref": "#/definitions/nonNegativeInteger" },
        "llmChatCompletionCount": { "$ref": "#/definitions/nonNegativeInteger" },
        "toolCallCount": { "$ref": "#/definitions/nonNegativeInteger" },
        "promptTokensDetails": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cacheHitTokens": { "$ref": "#/definitions/nonNegativeInteger" },
            "cacheMissTokens": { "$ref": "#/definitions/nonNegativeInteger" }
          }
        },
        "completionTokensDetails": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reasoningTokens": { "$ref": "#/definitions/nonNegativeInteger" }
          }
        },
        "estimatedCost": { "$ref": "#/definitions/estimatedCost" },
        "timing": { "$ref": "#/definitions/usageTiming" }
      }
    },
    "reactContextWindow": {
      "type": "object",
      "required": ["currentSize", "maxSize"],
      "additionalProperties": false,
      "properties": {
        "maxSize": {
          "type": "integer",
          "minimum": 1
        },
        "currentSize": { "$ref": "#/definitions/nonNegativeInteger" },
        "estimatedNextCallSize": { "$ref": "#/definitions/nonNegativeInteger" }
      }
    },
    "toolCallFunction": {
      "type": "object",
      "required": ["name", "arguments"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "arguments": { "type": "string" }
      }
    },
    "toolCall": {
      "type": "object",
      "required": ["id", "type", "function"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["function"] },
        "function": { "$ref": "#/definitions/toolCallFunction" }
      }
    },
    "llmChatRole": {
      "type": "string",
      "enum": ["system", "developer", "user", "assistant", "tool"]
    },
    "llmChatMessageContent": {
      "anyOf": [
        { "type": "string" },
        { "type": "array" },
        { "type": "null" }
      ]
    },
    "llmChatMessage": {
      "type": "object",
      "required": ["role", "content"],
      "additionalProperties": true,
      "properties": {
        "role": { "$ref": "#/definitions/llmChatRole" },
        "content": { "$ref": "#/definitions/llmChatMessageContent" },
        "name": { "type": "string" },
        "tool_call_id": { "type": "string" },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/definitions/toolCall" }
        }
      }
    },
    "llmChatMessages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/llmChatMessage" }
    },
    "llmToolChoice": {
      "anyOf": [
        { "type": "string", "enum": ["auto", "none", "required"] },
        { "type": "object", "additionalProperties": true }
      ]
    },
    "llmStreamOptions": {
      "type": "object",
      "required": ["include_usage"],
      "additionalProperties": true,
      "properties": {
        "include_usage": { "type": "boolean" }
      }
    },
    "llmRequestOptions": {
      "type": "object",
      "required": ["stream", "stream_options", "temperature"],
      "additionalProperties": true,
      "properties": {
        "stream": { "type": "boolean" },
        "stream_options": { "$ref": "#/definitions/llmStreamOptions" },
        "temperature": { "type": "number" }
      }
    },
    "message": {
      "type": "object",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "role": { "$ref": "#/definitions/role" },
        "content": { "type": "array" },
        "ts": { "type": "number" },
        "durationMs": { "$ref": "#/definitions/nonNegativeNumber" },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/definitions/toolCall" }
        },
        "name": { "type": "string" },
        "tool_call_id": { "type": "string" },
        "reasoning_content": { "type": "array" },
        "approval": { "type": "object", "additionalProperties": true },
        "_reasoningId": { "type": "string" },
        "_contentId": { "type": "string" },
        "_msgId": { "type": "string" },
        "_toolId": { "type": "string" },
        "_actionId": { "type": "string" },
        "_liveSeq": { "$ref": "#/definitions/positiveInteger" }
      }
    },
    "awaitingItem": {
      "type": "object",
      "required": [
        "awaitingId",
        "mode",
        "type",
        "runId",
        "agentKey",
        "timestamp",
        "timeout",
        "viewportType",
        "viewportKey"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["mode"],
            "properties": {
              "mode": { "const": "approval" }
            }
          },
          "then": {
            "required": ["approvals"]
          }
        },
        {
          "if": {
            "required": ["mode"],
            "properties": {
              "mode": { "const": "question" }
            }
          },
          "then": {
            "required": ["questions"]
          }
        },
        {
          "if": {
            "required": ["mode"],
            "properties": {
              "mode": { "const": "form" }
            }
          },
          "then": {
            "required": ["forms"]
          }
        },
        {
          "if": {
            "required": ["mode"],
            "properties": {
              "mode": { "const": "plan" }
            }
          },
          "then": {
            "required": ["plan"]
          }
        }
      ],
      "properties": {
        "awaitingId": { "type": "string" },
        "mode": { "type": "string", "enum": ["approval", "question", "form", "plan"] },
        "type": { "type": "string", "enum": ["awaiting.ask"] },
        "runId": { "type": "string" },
        "agentKey": { "type": "string" },
        "timestamp": { "type": "number" },
        "timeout": { "type": "number" },
        "viewportType": { "type": "string" },
        "viewportKey": { "type": "string" },
        "questions": { "$ref": "#/definitions/awaitingObjectArray" },
        "approvals": { "$ref": "#/definitions/awaitingObjectArray" },
        "forms": { "$ref": "#/definitions/awaitingObjectArray" },
        "plan": { "$ref": "#/definitions/awaitingPlan" }
      }
    },
    "awaitingObjectArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "awaitingPlan": {
      "type": "object",
      "required": ["id", "title", "options"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "planningFile": { "type": "string" },
        "planningId": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/awaitingPlanOption" }
        }
      }
    },
    "awaitingPlanOption": {
      "type": "object",
      "required": ["decision", "label"],
      "additionalProperties": true,
      "properties": {
        "decision": { "type": "string" },
        "label": { "type": "string" },
        "input": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "planningEvent": {
      "type": "object",
      "required": ["type", "planningId", "chatId", "runId", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/definitions/streamEventType" },
        "planningId": { "type": "string" },
        "chatId": { "type": "string" },
        "runId": { "type": "string" },
        "timestamp": { "type": "number" },
        "planningFile": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "eventPayload": {
      "type": "object",
      "required": ["type", "timestamp"],
      "additionalProperties": true,
      "properties": {
        "type": { "$ref": "#/definitions/streamEventType" },
        "timestamp": { "type": "number" },
        "seq": { "$ref": "#/definitions/positiveInteger" },
        "chatId": { "type": "string" },
        "runId": { "type": "string" },
        "requestId": { "type": "string" },
        "agentKey": { "type": "string" },
        "taskId": { "type": "string" }
      }
    },
    "steerPayload": {
      "type": "object",
      "required": ["requestId", "chatId", "runId", "steerId", "message", "role"],
      "additionalProperties": true,
      "properties": {
        "requestId": { "type": "string" },
        "chatId": { "type": "string" },
        "runId": { "type": "string" },
        "steerId": { "type": "string" },
        "message": { "type": "string" },
        "role": { "$ref": "#/definitions/role" },
        "timestamp": { "type": "number" }
      }
    },
    "systemMessage": {
      "type": "object",
      "required": ["role", "content"],
      "additionalProperties": false,
      "properties": {
        "role": { "$ref": "#/definitions/role" },
        "content": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" }
          ]
        },
        "name": { "type": "string" }
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": true
    },
    "messageArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/message" }
    },
    "awaitingArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/awaitingItem" }
    }
  }
}
